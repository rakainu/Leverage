# Solana RPC (Helius recommended — helius.dev)
SMC_SOLANA_RPC_URLS=["https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"]
SMC_SOLANA_WS_URLS=["wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY"]
SMC_SOLANA_PRIVATE_KEY=your_base58_keypair_here

# Mode: "paper" or "live"
SMC_MODE=paper

# Trading parameters
SMC_CONVERGENCE_WINDOW_MINUTES=60
SMC_CONVERGENCE_THRESHOLD=3
SMC_MAX_CONCURRENT_POSITIONS=5
SMC_TRADE_AMOUNT_SOL=0.25
SMC_STOP_LOSS_PCT=25.0
SMC_POSITION_TIMEOUT_MINUTES=240

# Jupiter (free key from portal.jup.ag)
SMC_JUPITER_API_KEY=

# Dashboard
SMC_DASHBOARD_PORT=8420

# Telegram
SMC_TELEGRAM_BOT_TOKEN=your_bot_token
SMC_TELEGRAM_CHAT_ID=your_chat_id

# Helius
SMC_HELIUS_API_KEY=your_helius_api_key
