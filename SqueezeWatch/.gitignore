# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env

# Config with secrets
config/config.json

# Data & outputs — snapshots can be large, don't commit raw history
data/history/*.csv
data/history/*.json
data/snapshots/*.csv
data/snapshots/*.json
outputs/daily/*.csv
outputs/daily/*.json
outputs/daily/*.md

# Keep the directory structure via .gitkeep
!**/.gitkeep

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
