# Secrets
.env
*.key
credentials*.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Python
__pycache__/
*.pyc
venv/
.venv/

# Node
node_modules/

# Logs
*.log

# Tool caches
.playwright-mcp/
.claude/scheduled_tasks.lock
.superpowers/
.scratch/

# blofin-bridge runtime
scripts/blofin-bridge/data/
scripts/blofin-bridge/*.db
scripts/blofin-bridge/*.db-journal
scripts/blofin-bridge/__pycache__/
scripts/blofin-bridge/src/**/__pycache__/
scripts/blofin-bridge/src/*.egg-info/

# scalping runtime (clone of blofin-bridge)
scripts/scalping/data/
scripts/scalping/*.db
scripts/scalping/*.db-journal
scripts/scalping/__pycache__/
scripts/scalping/src/**/__pycache__/
scripts/scalping/src/*.egg-info/

# scalping analysis data (sweep outputs, regenerable)
scripts/scalping/analysis/data/*.db
scripts/scalping/analysis/data/*.db-journal

# Local diagnostic artifacts (not source)
Screenshot*.png
*.png.bak

# Fetched market data (reproducible via fetch scripts)
*.parquet

# Local off-site backup tarballs (contain .env secrets — never commit)
_local_backups/

# Dashboard preview artifacts (throwaway)
v32_*.png
.playwright-mcp/
scripts/scalping/v3.2-dashboard/*.db

# Data (large binaries — fetched/cached, never commit)
*.parquet
data_hist/

# Apex bridge runtime
scripts/apex/data/

# Pytest cache noise
**/.pytest_cache/
