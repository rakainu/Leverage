# BloFin × TradingView webhook bridge credentials — TEMPLATE
# Copy this file to .env and fill in real values. .env is gitignored.

# --- BloFin LIVE keys (blofin.com > Account > API Management) ---
BLOFIN_LIVE_API_KEY=your_live_api_key_here
BLOFIN_LIVE_API_SECRET=your_live_api_secret_here
BLOFIN_LIVE_PASSPHRASE=your_live_passphrase_here

# --- BloFin DEMO keys (demo-trading.blofin.com > API Management) ---
# Separate account + separate keys from live. Generated in BloFin's Demo Trading UI.
BLOFIN_DEMO_API_KEY=your_demo_api_key_here
BLOFIN_DEMO_API_SECRET=your_demo_api_secret_here
BLOFIN_DEMO_PASSPHRASE=your_demo_passphrase_here

# demo | live
BLOFIN_ENV=demo

# --- Bridge auth ---
BRIDGE_SECRET=change_me_to_a_long_random_string

# --- Telegram notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
